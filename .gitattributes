# Normalize text files to LF in the repository and working tree.
* text=auto eol=lf

# Common text formats used by this Jekyll site.
*.md      text eol=lf
*.html    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.json    text eol=lf
*.js      text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.rb      text eol=lf
*.py      text eol=lf
*.sh      text eol=lf
*.xml     text eol=lf
*.txt     text eol=lf
*.csv     text eol=lf
*.ipynb   text eol=lf

# Binary assets must never be newline-normalized.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.webp    binary
*.svgz    binary
*.ico     binary
*.pdf     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.eot     binary
*.zip     binary
*.tar     binary
*.gz      binary

{
  "name": "qselmer-github-io",
  "version": "1.0.0",
  "private": true,
  "description": "JavaScript build pipeline for qselmer.github.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/qselmer/qselmer.github.io"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "jquery": "3.7.1"
  },
  "devDependencies": {
    "onchange": "7.1.0",
    "uglify-js": "3.19.3"
  },
  "scripts": {
    "build:js": "uglifyjs node_modules/jquery/dist/jquery.min.js assets/js/plugins/jquery.greedy-navigation.js assets/js/_main.js assets/js/theme.js --compress --mangle --output assets/js/main.min.js",
    "watch:js": "onchange \"assets/js/**/*.js\" --exclude \"assets/js/main.min.js\" -- npm run build:js",
    "check:js": "node --check assets/js/_main.js && node --check assets/js/plugins/jquery.greedy-navigation.js && node --check assets/js/theme.js",
    "test": "npm run check:js && npm run build:js"
  }
}
